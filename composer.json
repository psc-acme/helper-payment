{
    "name": "psc-acme/helper-payment",
    "description": "Package helper-payment for psc-acme organization",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Philipp Scheit",
            "email": "p.scheit@packagist.com"
        }
    ],
    "autoload": {
        "psr-4": {
            "PscAcme\\HelperPayment\\": "src/"
        }
    },
    "require": {
        "php": ">=8.1",
        "symfony/serializer": "^7.0",
        "league/flysystem": "^3.0",
        "doctrine/dbal": "^4.0",
        "psc-acme/connector-user": "^1.0"
    },
    "require-dev": {
        "phpstan/phpstan": "^1.0",
        "webforge/object-asserter": "^2.0.0"
    },
    "minimum-stability": "stable",
    "config": {
        "secure-http": false
    },
    "repositories": {
        "private-packagist": {
            "type": "composer",
            "url": "http://repo.packagist.com.lo/psc-acme/"
        },
        "packagist.org": false
    }
}